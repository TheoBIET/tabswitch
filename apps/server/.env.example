PORT=4000
NODE_ENV=development
LOG_LEVEL=debug

# Origin of the web app (CORS)
WEB_ORIGIN=http://localhost:3000

# Shared with the web app — must match NEXTAUTH_SECRET / SESSION_SECRET
SESSION_SECRET=dev-secret-change-me-min-32-chars-required-here

# Redis. Leave empty to use in-memory fallback (dev only, single-process).
REDIS_URL=redis://localhost:6379
