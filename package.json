{
  "name": "tabswitch",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@tabswitch/web",
    "dev:server": "turbo run dev --filter=@tabswitch/server",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "redis:up": "docker compose -f infra/docker-compose.dev.yml up -d redis",
    "pg:up": "docker compose -f infra/docker-compose.dev.yml up -d postgres",
    "infra:up": "docker compose -f infra/docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.dev.yml down",
    "db:push": "pnpm --filter @tabswitch/db push",
    "db:generate": "pnpm --filter @tabswitch/db generate",
    "db:studio": "pnpm --filter @tabswitch/db studio"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
